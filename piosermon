#!/bin/bash
# Serial monitor (with reset/bootloader support) for a named USB device.
# Usage: piosermon [args...] <device-name>
set -euo pipefail
source "$(dirname "$0")/pio-common.sh"

show_usage() {
    echo "Usage: piosermon [args...] <device-name>"
    echo ""
    echo "Open serial-monitor for a device. Supports Ctrl-R (reset), Ctrl-B"
    echo "(bootloader), auto-reconnect, and timestamps. Last argument is the"
    echo "device name (resolved by usb-device). All other arguments are passed"
    echo "to serial-monitor."
    echo ""
    echo "Examples:"
    echo "  piosermon 1.10"
    echo "  piosermon --timeout 30 1.10"
    echo "  piosermon --reset 1.10"
    echo ""
    echo "See also: piomonitor (uses PlatformIO's built-in monitor)"
}

pio_check_help "$@" && { show_usage; exit 0; }

if ! pio_parse_args "$@"; then
    show_usage >&2
    exit 1
fi

port=$(usb-device port "$PIO_DEV") || exit 1
pio_lock "$PIO_DEV" "serial-monitor" || exit 1
trap pio_cleanup EXIT
pio_log_setup sermon
pio_exec serial-monitor "$port" ${PIO_ARGS[@]+"${PIO_ARGS[@]}"}
