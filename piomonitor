#!/bin/bash
# Serial monitor for a named USB device.
# Usage: piomonitor [args...] <device-name>
set -euo pipefail

if [ $# -lt 1 ]; then
    echo "Usage: piomonitor [args...] <device-name>"
    echo ""
    echo "Open a serial monitor for a device. Last argument is the device name"
    echo "(resolved by usb-device). All other arguments are passed to serial-monitor."
    echo ""
    echo "Examples:"
    echo "  piomonitor 1.10"
    echo "  piomonitor --timeout 30 1.10"
    exit 1
fi

dev="${@:$#}"
args=("${@:1:$#-1}")
port=$(usb-device port "$dev") || exit 1

exec serial-monitor "$port" ${args[@]+"${args[@]}"}
