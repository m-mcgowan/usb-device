#!/bin/bash
# PlatformIO serial monitor for a named USB device.
# Usage: piomonitor [args...] <device-name>
set -euo pipefail
source "$(dirname "$0")/pio-common.sh"

show_usage() {
    echo "Usage: piomonitor [args...] <device-name>"
    echo ""
    echo "Open a PlatformIO serial monitor for a device. Last argument is the"
    echo "device name (resolved by usb-device). All other arguments are passed"
    echo "to 'pio device monitor'."
    echo ""
    echo "Examples:"
    echo "  piomonitor 1.10"
    echo "  piomonitor -e esp32s3-idf 1.10"
    echo ""
    echo "See also: piosermon (uses serial-monitor with reset/bootloader support)"
}

pio_check_help "$@" && { show_usage; exit 0; }

pio_parse_args "$@"
rc=$?
if [ "$rc" -eq 1 ]; then show_usage >&2; exit 1; fi
[ "$rc" -eq 0 ] || exit "$rc"

port=$(usb-device port "$PIO_DEV") || exit 1
pio_lock "$PIO_DEV" "monitor" || exit 1
trap pio_cleanup EXIT
pio_log_setup monitor
pio_exec pio device monitor --port "$port" --baud 115200 --eol LF ${PIO_ARGS[@]+"${PIO_ARGS[@]}"}
