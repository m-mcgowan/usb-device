# labgrid exporter configuration for usb-device managed hardware.
#
# Each entry creates a labgrid "place" backed by a usb-device group.
# Partners are auto-discovered from devices.conf.
#
# Run manually:
#   export LG_COORDINATOR=localhost:20408
#   python -m labgrid_usb_device.run_exporter -c $LG_COORDINATOR exporter.yaml
#
# Or install as a macOS launchd service (see README.md).

# Add one entry per device group. The device_name must match a section
# in your devices.conf. Partners (e.g. [My Board:debugger]) are
# auto-discovered.
#
# Place names should be descriptive: location-board-peripherals
# Example: workshop-mpcb-1.10-ppk2-1
#
# Tags (fixture metadata) are defined separately in fixtures.yaml.

# workshop-mpcb-1.10-ppk2-1:
#   USBDevice:
#     device_name: "My Board Rev A"
#
# lab-mpcb-1.9-standalone-1:
#   USBDevice:
#     device_name: "My Board Rev B"
