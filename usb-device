# usb-device — look up and manage named USB devices via uhubctl
#
# Usage:
#   usb-device list                  # show all registered devices and their status
#   usb-device scan                  # scan bus and update last-known locations
#   usb-device find "1.9"            # show hub/port/serial (substring match)
#   usb-device reset "dev"           # power-cycle a device (escalates to hub if needed)
#   usb-device reset -f "dev"        # force reset (skip hub confirmation)
#   usb-device off "MPCB.*Dev"       # turn off power (regex match)
#   usb-device on "1.9"              # turn on power to a device
#   usb-device port "1.9"            # print /dev/cu.* path
#   usb-device partners "1.9"        # list partner devices for a board
#
# Config supports INI-style sections with partner devices:
#   [MPCB 1.9 Development]
#   mac=B8:F8:62:D2:2A:FC
#   type=esp32
#
#   [MPCB 1.9 Development:ppk2]
#   serial=C9F6358AC307
#   type=ppk2
#
# Legacy flat format still works: NAME=MAC (treated as type=generic)
#
# Device names support fuzzy matching:
#   - Exact match tried first (case-insensitive)
#   - If pattern contains regex chars: matched as regex
#   - Otherwise: matched as case-insensitive substring
#   - Multiple matches: interactive selection prompt
#   - No matches: shows list of known devices

CONFIG_DIR="${USB_DEVICE_CONFIG_DIR:-$HOME/.config/usb-devices}"
CONF="${USB_DEVICE_CONF:-$CONFIG_DIR/devices.conf}"
DB="${USB_DEVICE_DB:-$CONFIG_DIR/locations.json}"

die() { echo "error: $*" >&2; exit 1; }

# Globals set by resolve_device()
RESOLVED_NAME=""
RESOLVED_MAC=""
RESOLVED_TYPE=""
RESOLVED_LOCATION=""
RESOLVED_CHIP=""
RESOLVED_HUB_NAME=""

# ── Type plugin loading ────────────────────────────────────────────

# Resolve symlinks so SCRIPT_DIR points to the real install location
# (needed for Homebrew which symlinks bin/ → libexec/)
_self="$0"
[ -L "$_self" ] && _self="$(readlink "$_self")"
SCRIPT_DIR="$(cd "$(dirname "$_self")" && pwd)"
unset _self

# Python with pyserial: env override → venv → system
if [ -n "${USB_DEVICE_PYTHON:-}" ]; then
    PYTHON="$USB_DEVICE_PYTHON"
elif [ -x "$SCRIPT_DIR/.venv/bin/python3" ]; then
    PYTHON="$SCRIPT_DIR/.venv/bin/python3"
else
    PYTHON="python3"
fi

USB_DEVICE_VERSION="$(cat "${SCRIPT_DIR}/VERSION" 2>/dev/null || echo "dev")"
TYPE_PLUGIN_DIRS=(
    "${SCRIPT_DIR}/types.d"
    "${CONFIG_DIR}/types.d"
)

# Source a type plugin. Returns 0 if found, 1 if not.
# After loading, type_<name>_* functions are available.
#
# Search order for each TYPE_PLUGIN_DIRS entry:
#   1. $dir/<name>.sh           (flat file)
#   2. $dir/<subdir>/<name>.sh  (subdirectory — supports symlinks)
#
# This allows projects to aggregate plugins by symlinking their types.d/
# into ~/.config/usb-devices/types.d/:
#   types.d/esp32.sh                       (shipped)
#   types.d/my-project -> /path/to/types/  (linked directory)
#     notecard.sh
#     ppk2.sh
load_type_plugin() {
    local type_name="$1"
    [ -n "$type_name" ] && [ "$type_name" != "generic" ] || return 1
    local dir subdir
    for dir in "${TYPE_PLUGIN_DIRS[@]}"; do
        # Direct match
        if [ -f "$dir/${type_name}.sh" ]; then
            source "$dir/${type_name}.sh"
            return 0
        fi
        # Search subdirectories (follows symlinks)
        for subdir in "$dir"/*/; do
            [ -d "$subdir" ] || continue
            if [ -f "$subdir${type_name}.sh" ]; then
                source "$subdir${type_name}.sh"
                return 0
            fi
        done
    done
    return 1
}

# ── Database helpers ──────────────────────────────────────────────

# Ensure the DB file exists with an empty JSON object
db_init() {
    [ -f "$DB" ] || echo '{}' > "$DB"
}

# Read a field from the DB for a device name
# Usage: db_get "MPCB 1.9 Development" "hub"
db_get() {
    db_init
    jq -r --arg name "$1" --arg field "$2" '.[$name][$field] // empty' "$DB"
}

# Update the DB: merge a device entry
# Usage: db_put "name" "mac" "hub" "port" "link" "serial_port"
db_put() {
    db_init
    local name="$1" mac="$2" hub="$3" port="$4" link="$5" serial_port="$6"
    local now
    now=$(date -u +%Y-%m-%dT%H:%M:%SZ)
    local tmp="${DB}.tmp.$$"
    jq --arg name "$name" \
       --arg mac "$mac" \
       --arg hub "$hub" \
       --arg port "$port" \
       --arg link "$link" \
       --arg dev "$serial_port" \
       --arg ts "$now" \
       '.[$name] = {mac: $mac, hub: $hub, port: $port, link: $link, dev: $dev, last_seen: $ts}' \
       "$DB" > "$tmp" && mv "$tmp" "$DB"
}

# Remove any DB entry that occupies a given hub:port (evict old device)
db_evict_port() {
    local hub="$1" port="$2" except_name="$3"
    db_init
    local tmp="${DB}.tmp.$$"
    jq --arg hub "$hub" --arg port "$port" --arg except "$except_name" \
       'to_entries | map(select(
            .value.hub != $hub or .value.port != $port or .key == $except
        )) | from_entries' \
       "$DB" > "$tmp" && mv "$tmp" "$DB"
}

# List all devices in DB that are on a given hub (optionally excluding one port)
# Outputs: "name|port" lines
db_devices_on_hub() {
    local hub="$1" exclude_port="${2:-}"
    db_init
    jq -r --arg hub "$hub" --arg ep "$exclude_port" \
       'to_entries[] | select(.value.hub == $hub and .value.port != $ep) |
        "\(.key)|\(.value.port)"' "$DB"
}

# ── Config parser (INI + legacy flat format) ─────────────────────
#
# Populates parallel arrays:
#   DEVICE_NAMES[i]     — device name (section header or flat line name)
#   DEVICE_MACS[i]      — serial number (from mac=, serial=, or flat line)
#   DEVICE_TYPES[i]     — esp32, ppk2, power (default: esp32)
#   DEVICE_LOCATIONS[i] — static USB location (for type=power)
#
DEVICE_NAMES=()
DEVICE_MACS=()
DEVICE_TYPES=()
DEVICE_LOCATIONS=()
DEVICE_CHIPS=()
DEVICE_HUB_NAMES=()
CONFIG_PARSED=0

# Hub config (from [hub:insight] sections)
HUB_CONF_PORT=""       # CDC serial port for Insight Hub
HUB_CONF_LOCATION=""   # uhubctl hub ID for Insight Hub

_flush_section() {
    local name="$1" mac="$2" type="$3" location="$4" chip="$5" hub_name="$6"
    [ -n "$name" ] || return 0

    # [hub:*] sections are hub config, not devices
    if [[ "$name" == hub:* ]]; then
        [ -n "$location" ] && HUB_CONF_LOCATION="$location"
        [ -n "$mac" ] && HUB_CONF_PORT="$mac"  # port= stored in mac slot
        return 0
    fi

    DEVICE_NAMES+=("$name")
    DEVICE_MACS+=("$mac")
    DEVICE_TYPES+=("${type:-generic}")
    DEVICE_LOCATIONS+=("$location")
    DEVICE_CHIPS+=("$chip")
    DEVICE_HUB_NAMES+=("$hub_name")
}

parse_config() {
    [ "$CONFIG_PARSED" -eq 0 ] || return 0
    CONFIG_PARSED=1

    DEVICE_NAMES=()
    DEVICE_MACS=()
    DEVICE_TYPES=()
    DEVICE_LOCATIONS=()
    DEVICE_CHIPS=()
    DEVICE_HUB_NAMES=()
    HUB_CONF_PORT=""
    HUB_CONF_LOCATION=""

    [ -f "$CONF" ] || return 0

    local section="" sec_mac="" sec_type="" sec_location="" sec_chip="" sec_hub_name=""

    while IFS= read -r line; do
        # Strip leading/trailing whitespace
        line="${line#"${line%%[![:space:]]*}"}"
        line="${line%"${line##*[![:space:]]}"}"

        # Skip comments and blank lines
        [[ "$line" =~ ^# || -z "$line" ]] && continue

        # Section header: [Name]
        if [[ "$line" =~ ^\[(.+)\]$ ]]; then
            _flush_section "$section" "$sec_mac" "$sec_type" "$sec_location" "$sec_chip" "$sec_hub_name"
            section="${BASH_REMATCH[1]}"
            sec_mac="" sec_type="" sec_location="" sec_chip="" sec_hub_name=""
            continue
        fi

        # Key=value inside a section
        if [ -n "$section" ] && [[ "$line" == *=* ]]; then
            local key="${line%%=*}" val="${line#*=}"
            key="${key#"${key%%[![:space:]]*}"}" key="${key%"${key##*[![:space:]]}"}"
            val="${val#"${val%%[![:space:]]*}"}" val="${val%"${val##*[![:space:]]}"}"
            case "$key" in
                mac|serial) sec_mac="$val" ;;
                type)       sec_type="$val" ;;
                location)   sec_location="$val" ;;
                chip)       sec_chip="$val" ;;
                hub_name)   sec_hub_name="$val" ;;
                port)       sec_mac="$val" ;;  # [hub:*] uses port= for CDC serial path
            esac
            continue
        fi

        # Legacy flat format: NAME=MAC (only outside sections)
        if [ -z "$section" ] && [[ "$line" == *=* ]]; then
            local flat_name="${line%%=*}" flat_mac="${line#*=}"
            _flush_section "$flat_name" "$flat_mac" "" "" "" ""
        fi
    done < "$CONF"

    # Flush last section
    _flush_section "$section" "$sec_mac" "$sec_type" "$sec_location" "$sec_chip" "$sec_hub_name"
}

# List all device names
all_device_names() {
    parse_config
    local i
    for i in "${!DEVICE_NAMES[@]}"; do
        echo "${DEVICE_NAMES[$i]}"
    done
}

# Check if a string contains regex special characters
is_regex() {
    [[ "$1" =~ [\[\]\(\)\{\}\.\*\+\?\^\$\|\\] ]]
}

# Set all resolved globals from a device index.
_resolve_from_index() {
    local idx="$1"
    RESOLVED_NAME="${DEVICE_NAMES[$idx]}"
    RESOLVED_MAC="${DEVICE_MACS[$idx]}"
    RESOLVED_TYPE="${DEVICE_TYPES[$idx]}"
    RESOLVED_LOCATION="${DEVICE_LOCATIONS[$idx]}"
    RESOLVED_CHIP="${DEVICE_CHIPS[$idx]}"
    RESOLVED_HUB_NAME="${DEVICE_HUB_NAMES[$idx]}"
}

# Check if a device name is a partner device (contains ':').
# Partner devices (e.g. "Board:ppk2") are excluded from fuzzy matching
# unless the search pattern itself contains ':'.
_is_partner_device() {
    [[ "$1" == *:* ]]
}

# Find all device indices matching a pattern. Sets MATCH_INDICES array.
# Returns 0 if any match found, 1 if none.
# Partner devices (name contains ':') are excluded from fuzzy matches
# unless the pattern itself contains ':'.
_find_matching_indices() {
    local pattern="$1"
    MATCH_INDICES=()
    local i
    local include_partners=0
    [[ "$pattern" == *:* ]] && include_partners=1

    # Exact match (case-insensitive) — always considers all devices
    for i in "${!DEVICE_NAMES[@]}"; do
        if echo "${DEVICE_NAMES[$i]}" | grep -iqx "$pattern"; then
            MATCH_INDICES=("$i")
            return 0
        fi
    done

    # Partner fuzzy match: split on ':', fuzzy-match primary, exact-match role
    if [ "$include_partners" -eq 1 ]; then
        local primary_pattern="${pattern%%:*}"
        local role_pattern="${pattern#*:}"
        # Find matching primary devices
        local primary_indices=()
        if is_regex "$primary_pattern"; then
            for i in "${!DEVICE_NAMES[@]}"; do
                _is_partner_device "${DEVICE_NAMES[$i]}" && continue
                echo "${DEVICE_NAMES[$i]}" | grep -iqE "$primary_pattern" && primary_indices+=("$i")
            done
        else
            for i in "${!DEVICE_NAMES[@]}"; do
                _is_partner_device "${DEVICE_NAMES[$i]}" && continue
                echo "${DEVICE_NAMES[$i]}" | grep -iqF "$primary_pattern" && primary_indices+=("$i")
            done
        fi
        # For each matching primary, check if primary:role exists
        local pi
        for pi in "${primary_indices[@]}"; do
            local composed="${DEVICE_NAMES[$pi]}:${role_pattern}"
            for i in "${!DEVICE_NAMES[@]}"; do
                if echo "${DEVICE_NAMES[$i]}" | grep -iqx "$composed"; then
                    MATCH_INDICES+=("$i")
                fi
            done
        done
    # Non-partner fuzzy match: regex if special chars detected, otherwise case-insensitive substring
    elif is_regex "$pattern"; then
        for i in "${!DEVICE_NAMES[@]}"; do
            _is_partner_device "${DEVICE_NAMES[$i]}" && continue
            echo "${DEVICE_NAMES[$i]}" | grep -iqE "$pattern" && MATCH_INDICES+=("$i")
        done
    else
        for i in "${!DEVICE_NAMES[@]}"; do
            _is_partner_device "${DEVICE_NAMES[$i]}" && continue
            echo "${DEVICE_NAMES[$i]}" | grep -iqF "$pattern" && MATCH_INDICES+=("$i")
        done
    fi

    [ ${#MATCH_INDICES[@]} -gt 0 ]
}

# Resolve a device pattern to RESOLVED_NAME, RESOLVED_MAC, RESOLVED_TYPE, RESOLVED_LOCATION.
# Supports exact, substring, and regex matching with interactive selection.
resolve_device() {
    parse_config
    local pattern="$1"
    RESOLVED_NAME=""
    RESOLVED_MAC=""
    RESOLVED_TYPE=""
    RESOLVED_LOCATION=""
    RESOLVED_CHIP=""
    RESOLVED_HUB_NAME=""

    if ! _find_matching_indices "$pattern"; then
        echo "No devices match '$pattern'" >&2
        echo "" >&2
        echo "Known devices:" >&2
        all_device_names | while read -r n; do echo "  $n" >&2; done
        exit 1
    fi

    if [ ${#MATCH_INDICES[@]} -eq 1 ]; then
        _resolve_from_index "${MATCH_INDICES[0]}"
        return 0
    fi

    # In checkout mode, partition matches into locked/unlocked
    local available_indices=()
    local locked_indices=()
    if [ "${_RESOLVE_CHECKOUT_MODE:-0}" -eq 1 ]; then
        mkdir -p "$LOCK_DIR"
        for i in "${MATCH_INDICES[@]}"; do
            if _is_locked "${DEVICE_NAMES[$i]}"; then
                locked_indices+=("$i")
            else
                available_indices+=("$i")
            fi
        done

        # Show locked devices first
        if [ ${#locked_indices[@]} -gt 0 ]; then
            for i in "${locked_indices[@]}"; do
                local lock_owner="${LOCK_OWNER:-?}"
                local lock_purpose="${LOCK_PURPOSE:+ ($LOCK_PURPOSE)}"
                echo "  ${DEVICE_NAMES[$i]} — locked by ${lock_owner}${lock_purpose}" >&2
            done
        fi

        # All locked — fail
        if [ ${#available_indices[@]} -eq 0 ]; then
            echo "All devices matching '$pattern' are locked" >&2
            return 1
        fi

        # Single unlocked device — auto-select
        if [ ${#available_indices[@]} -eq 1 ]; then
            _resolve_from_index "${available_indices[0]}"
            return 0
        fi

        # Replace MATCH_INDICES with only available devices
        MATCH_INDICES=("${available_indices[@]}")
    fi

    # Multiple matches — interactive selection
    echo "Multiple devices match '$pattern':" >&2
    local i
    for i in "${!MATCH_INDICES[@]}"; do
        echo "  $((i+1))) ${DEVICE_NAMES[${MATCH_INDICES[$i]}]}" >&2
    done
    printf "Select [1-%d]: " "${#MATCH_INDICES[@]}" >&2
    local choice
    read -r choice
    if [[ "$choice" =~ ^[0-9]+$ ]] && [ "$choice" -ge 1 ] && [ "$choice" -le ${#MATCH_INDICES[@]} ]; then
        _resolve_from_index "${MATCH_INDICES[$((choice - 1))]}"
        return 0
    else
        die "invalid selection"
    fi
}

# ── USB discovery ─────────────────────────────────────────────────

# Find hub and port for a MAC address (live lookup).
# First tries uhubctl directly. If the device is behind a ganged sub-hub,
# falls back to pyserial's LOCATION field to find the nearest controllable port.
find_hub_port_live() {
    local mac="$1"
    local norm
    norm=$(normalize_mac "$mac")

    # Try direct match in uhubctl output (normalized comparison)
    local hub="" port=""
    while IFS= read -r line; do
        if [[ "$line" =~ "hub " ]]; then
            hub=$(echo "$line" | sed -E 's/.*hub ([^ ,]+).*/\1/')
        fi
        local line_norm
        line_norm=$(echo "$line" | tr -d ':-' | tr '[:upper:]' '[:lower:]')
        if [[ "$line_norm" == *"$norm"* ]]; then
            port=$(echo "$line" | sed -E 's/.*Port ([0-9]+).*/\1/')
            echo "$hub $port direct"
            return 0
        fi
    done < <(uhubctl 2>/dev/null)

    # Fallback: use pyserial LOCATION to find nearest controllable hub/port
    local location
    location=$($PYTHON -c "
from serial.tools.list_ports import comports
norm = '$norm'
for p in comports():
    sn = (p.serial_number or '').replace(':', '').replace('-', '').lower()
    if sn == norm:
        print(p.location or '')
        break
" 2>/dev/null)
    [ -n "$location" ] || return 1

    # Collect known uhubctl hub IDs
    local -a known_hubs=()
    while IFS= read -r line; do
        if [[ "$line" =~ "hub " ]]; then
            local hub_id
            hub_id=$(echo "$line" | sed -E 's/.*hub ([^ ,]+).*/\1/')
            known_hubs+=("$hub_id")
        fi
    done < <(uhubctl 2>/dev/null)

    # LOCATION e.g. "20-2.1.3" — find the longest matching hub prefix
    # then the next segment is the port on that hub
    local best_hub="" best_port=""
    for h in "${known_hubs[@]}"; do
        if [[ "$location" == "$h."* ]]; then
            local remainder="${location#"$h".}"
            local first_port="${remainder%%.*}"
            if [ -z "$best_hub" ] || [ ${#h} -gt ${#best_hub} ]; then
                best_hub="$h"
                best_port="$first_port"
            fi
        fi
    done

    if [ -n "$best_hub" ]; then
        echo "$best_hub $best_port indirect"
        return 0
    fi

    return 1
}

# Find hub and port: tries live first, falls back to DB
find_hub_port() {
    local mac="$1" name="${2:-}"
    local result

    if result=$(find_hub_port_live "$mac"); then
        echo "$result"
        return 0
    fi

    # Fall back to last-known location from DB
    if [ -n "$name" ]; then
        local db_hub db_port db_link
        db_hub=$(db_get "$name" "hub")
        db_port=$(db_get "$name" "port")
        db_link=$(db_get "$name" "link")
        if [ -n "$db_hub" ] && [ -n "$db_port" ]; then
            echo "$db_hub $db_port ${db_link:-unknown} cached"
            return 0
        fi
    fi

    return 1
}

# Normalize a MAC/serial: strip colons, dashes, lowercase
normalize_mac() { echo "${1//[:\-]/}" | tr '[:upper:]' '[:lower:]'; }

# Find /dev/cu.* path for a MAC address via pyserial (normalized comparison)
find_serial_port() {
    local mac="$1"
    local norm
    norm=$(normalize_mac "$mac")
    $PYTHON -c "
from serial.tools.list_ports import comports
norm = '$norm'
for p in comports():
    sn = (p.serial_number or '').replace(':', '').replace('-', '').lower()
    if sn == norm:
        print(p.device)
        break
" 2>/dev/null
}

# Detect USB device mode (app vs bootloader) by product string
# Returns: "app", "bootloader", or empty if not found
detect_device_mode() {
    local mac="$1"
    local norm
    norm=$(normalize_mac "$mac")
    $PYTHON -c "
from serial.tools.list_ports import comports
norm = '$norm'
for p in comports():
    sn = (p.serial_number or '').replace(':', '').replace('-', '').lower()
    if sn == norm:
        if p.product == 'USB JTAG/serial debug unit':
            print('bootloader')
        else:
            print('app')
        break
" 2>/dev/null
}

# Parse a static location string (e.g. "20-2.3") into hub and port.
# Location format: HUB.PORT where HUB may contain dots (e.g. "20-2.1.3" → hub=20-2.1, port=3)
parse_static_location() {
    local location="$1"
    local hub="${location%.*}"
    local port="${location##*.}"
    echo "$hub $port"
}

# ── Insight Hub power control ──────────────────────────────────────
#
# The Insight Hub's Renesas chip doesn't support uhubctl power switching.
# Power is controlled via the ESP32's JSON serial API (insight_hub.py).
# These helpers detect Insight Hub devices and route power commands
# through the serial API instead of uhubctl.

# Detect Insight Hub and set INSIGHT_HUB_LOCATION.
# Returns 0 if found, 1 if not.
_insight_hub_detect() {
    local result
    result=$("$PYTHON" "$SCRIPT_DIR/insight_hub.py" detect 2>/dev/null) || return 1
    INSIGHT_HUB_LOCATION="${result##*	}"   # field after tab
    return 0
}

# Check if the resolved device is behind an Insight Hub.
# Sets INSIGHT_HUB_CHANNEL if so. Returns 0 if yes, 1 if not.
_is_insight_hub_device() {
    [ -n "${INSIGHT_HUB_LOCATION:-}" ] || _insight_hub_detect || return 1
    # Device's hub must match (or be a child of) the Insight Hub location
    case "$HUB" in
        "$INSIGHT_HUB_LOCATION"|"$INSIGHT_HUB_LOCATION".*) ;;
        *) return 1 ;;
    esac
    # Map port to channel (1-3)
    INSIGHT_HUB_CHANNEL=$("$PYTHON" "$SCRIPT_DIR/insight_hub.py" channel "$INSIGHT_HUB_LOCATION" "$PORT" 2>/dev/null) || return 1
    return 0
}

# Power control via Insight Hub serial API.
# Usage: _insight_hub_power <on|off|cycle> [off_seconds]
_insight_hub_power() {
    local action="$1"
    local off_seconds="${2:-2}"
    case "$action" in
        on|off)
            "$PYTHON" "$SCRIPT_DIR/insight_hub.py" power "$INSIGHT_HUB_CHANNEL" "$action"
            ;;
        cycle)
            "$PYTHON" "$SCRIPT_DIR/insight_hub.py" cycle "$INSIGHT_HUB_CHANNEL" "$off_seconds"
            ;;
    esac
}

# Resolve to hub/port, storing results in HUB, PORT, HOW globals.
# Requires resolve_device() to have been called first.
resolve_hub_port() {
    # Static-location devices: use location directly
    if [ -n "$RESOLVED_LOCATION" ]; then
        read -r HUB PORT <<< "$(parse_static_location "$RESOLVED_LOCATION")"
        HOW="static"
        CACHED=""
        return 0
    fi

    [ -n "$RESOLVED_MAC" ] || die "'$RESOLVED_NAME' has no serial number or location configured"

    local result
    result=$(find_hub_port "$RESOLVED_MAC" "$RESOLVED_NAME") || \
        die "'$RESOLVED_NAME' ($RESOLVED_MAC) not found on any uhubctl-managed hub (and no last-known location in DB)"
    read -r HUB PORT HOW CACHED <<< "$result"
    if [ "$CACHED" = "cached" ]; then
        echo "Note: using last-known location from DB (device not currently visible)" >&2
    fi
    [ "$HOW" = "indirect" ] && echo "Note: device is behind a sub-hub on port $PORT — this will affect all devices on that sub-hub" >&2
}

# Check if a device is responsive (has a serial port)
device_is_alive() {
    local mac="$1"
    local port
    port=$(find_serial_port "$mac")
    [ -n "$port" ]
}

# ── Device locking (checkout/checkin) ─────────────────────────────
#
# Provides exclusive access to devices for CI jobs and manual use.
# Lock is a directory under LOCK_DIR (atomic mkdir).
# Lock metadata: PID, owner, timestamp, purpose, TTL, process details.
# Stale locks auto-reclaimed via PID liveness (with start-time verification) and TTL expiry.

LOCK_DIR="${USB_DEVICE_LOCK_DIR:-/tmp/usb-device-locks}"

# Sanitize a device name into a safe filename
_lock_key() {
    echo "$1" | tr ' /[:upper:]' '_-[:lower:]'
}

_lock_path() {
    echo "$LOCK_DIR/$(_lock_key "$1")"
}

# Write lock info file. Args: lock_path pid owner purpose ttl
_write_lock_info() {
    local lock_path="$1" pid="$2" owner="$3" purpose="$4" ttl="$5"
    cat > "$lock_path/info" <<EOF
PID=$pid
OWNER=$owner
TIMESTAMP=$(date -u +%Y-%m-%dT%H:%M:%SZ)
PURPOSE=$purpose
TTL=$ttl
LSTART=$(ps -p "$pid" -o lstart= 2>/dev/null)
COMM=$(ps -p "$pid" -o comm= 2>/dev/null)
EOF
}

# Read a field from the lock info file
_lock_field() {
    local lock_path="$1" field="$2"
    [ -f "$lock_path/info" ] || return 1
    grep "^${field}=" "$lock_path/info" 2>/dev/null | cut -d= -f2-
}

# Parse an ISO 8601 UTC timestamp to epoch seconds.
_parse_utc_timestamp() {
    local ts="$1"
    # macOS: -jf parses format string; must set TZ=UTC since the Z is literal
    TZ=UTC date -jf "%Y-%m-%dT%H:%M:%SZ" "$ts" +%s 2>/dev/null || \
        date -d "$ts" +%s 2>/dev/null
}

# Format seconds as human-readable duration (e.g. "2m 30s", "1h 15m").
_format_duration() {
    local secs="$1"
    if [ "$secs" -lt 60 ]; then
        echo "${secs}s"
    elif [ "$secs" -lt 3600 ]; then
        echo "$((secs / 60))m $((secs % 60))s"
    elif [ "$secs" -lt 86400 ]; then
        echo "$((secs / 3600))h $((secs % 3600 / 60))m"
    else
        echo "$((secs / 86400))d $((secs % 86400 / 3600))h"
    fi
}

# Format a UTC ISO timestamp as local time (e.g. "Mon 14:32").
_format_local_time() {
    local ts="$1"
    local epoch
    epoch=$(_parse_utc_timestamp "$ts") || return 1
    # macOS: -jf with epoch; Linux: -d @epoch
    date -r "$epoch" "+%a %H:%M" 2>/dev/null || \
        date -d "@$epoch" "+%a %H:%M" 2>/dev/null
}

# Check if target_pid is an ancestor of child_pid (walks the process tree).
_is_ancestor_pid() {
    local target_pid="$1" child_pid="$2"
    local current="$child_pid"
    # Walk up the process tree (limit depth to avoid infinite loops)
    local depth=0
    while [ "$depth" -lt 20 ]; do
        local parent
        parent=$(ps -o ppid= -p "$current" 2>/dev/null | tr -d ' ') || return 1
        [ -n "$parent" ] || return 1
        [ "$parent" = "$target_pid" ] && return 0
        # Reached init/launchd — stop
        [ "$parent" = "1" ] || [ "$parent" = "0" ] && return 1
        current="$parent"
        depth=$((depth + 1))
    done
    return 1
}

# Check if a lock is stale and reclaim it if so. Returns 0 if reclaimed/absent.
_try_reclaim_lock() {
    local lock_path="$1"
    [ -d "$lock_path" ] || return 0

    local lock_pid lock_ts lock_ttl
    lock_pid=$(_lock_field "$lock_path" "PID")
    lock_ts=$(_lock_field "$lock_path" "TIMESTAMP")
    lock_ttl=$(_lock_field "$lock_path" "TTL")

    # PID dead or recycled? kill -0 fails with EPERM if process exists but is owned
    # by another user, and with ESRCH if the process doesn't exist. We only reclaim
    # on ESRCH or when the process start time doesn't match (PID recycled).
    if [ -n "$lock_pid" ]; then
        if kill -0 "$lock_pid" 2>/dev/null; then
            # Process is alive — verify it's the same process via start time
            local lock_lstart current_lstart
            lock_lstart=$(_lock_field "$lock_path" "LSTART")
            if [ -n "$lock_lstart" ]; then
                current_lstart=$(ps -p "$lock_pid" -o lstart= 2>/dev/null)
                if [ -n "$current_lstart" ] && [ "$current_lstart" != "$lock_lstart" ]; then
                    local owner
                    owner=$(_lock_field "$lock_path" "OWNER")
                    echo "Reclaiming stale lock (PID $lock_pid recycled, was: ${owner:-unknown})" >&2
                    rm -rf "$lock_path"
                    return 0
                fi
            fi
        elif kill -0 "$lock_pid" 2>&1 | grep -q "No such process"; then
            local owner
            owner=$(_lock_field "$lock_path" "OWNER")
            echo "Reclaiming stale lock (PID $lock_pid dead, was: ${owner:-unknown})" >&2
            rm -rf "$lock_path"
            return 0
        fi
        # EPERM = process exists but owned by root/other — leave lock alone
    fi

    # TTL expired?
    if [ -n "$lock_ts" ] && [ -n "$lock_ttl" ] && [ "$lock_ttl" -gt 0 ] 2>/dev/null; then
        local now lock_epoch
        now=$(date +%s)
        lock_epoch=$(_parse_utc_timestamp "$lock_ts") || return 1
        if [ $((now - lock_epoch)) -gt "$lock_ttl" ]; then
            local owner age
            owner=$(_lock_field "$lock_path" "OWNER")
            age=$(_format_duration $((now - lock_epoch)))
            echo "Reclaiming expired lock (age $age > TTL ${lock_ttl}s, was: ${owner:-unknown})" >&2
            rm -rf "$lock_path"
            return 0
        fi
    fi

    return 1  # lock is valid, not reclaimed
}

# Print lock info to stderr
_show_lock_holder() {
    local lock_path="$1"
    [ -f "$lock_path/info" ] || return
    local owner pid purpose ts ttl
    owner=$(_lock_field "$lock_path" "OWNER")
    pid=$(_lock_field "$lock_path" "PID")
    purpose=$(_lock_field "$lock_path" "PURPOSE")
    ts=$(_lock_field "$lock_path" "TIMESTAMP")
    ttl=$(_lock_field "$lock_path" "TTL")
    local comm
    comm=$(_lock_field "$lock_path" "COMM")
    echo "  owner:   ${owner:--}" >&2
    if [ -n "$comm" ]; then
        echo "  pid:     ${pid:--} ($comm)" >&2
    else
        echo "  pid:     ${pid:--}" >&2
    fi
    [ -n "$purpose" ] && echo "  purpose: $purpose" >&2
    if [ -n "$ts" ]; then
        local local_time age_str
        local_time=$(_format_local_time "$ts") || local_time="$ts"
        local lock_epoch now
        now=$(date +%s)
        lock_epoch=$(_parse_utc_timestamp "$ts") || lock_epoch=0
        if [ "$lock_epoch" -gt 0 ]; then
            age_str=$(_format_duration $((now - lock_epoch)))
            echo "  since:   $local_time ($age_str ago)" >&2
        else
            echo "  since:   $local_time" >&2
        fi
    else
        echo "  since:   -" >&2
    fi
    [ -n "$ttl" ] && [ "$ttl" -gt 0 ] 2>/dev/null && echo "  ttl:     $(_format_duration "$ttl")" >&2
}

# Acquire a single device lock. Internal — called by cmd_checkout.
# Returns 0 on success, 1 on failure.
_checkout_one() {
    local name="$1" owner="$2" purpose="$3" ttl="$4" wait="$5" deadline="$6"

    resolve_device "$name" || return 1
    local lock_path
    lock_path=$(_lock_path "$RESOLVED_NAME")

    # Lock PID precedence: explicit --pid, inherited env var, parent PID
    local my_pid="${_lock_pid:-${USB_DEVICE_LOCK_PID:-$PPID}}"

    while true; do
        _try_reclaim_lock "$lock_path"

        if mkdir "$lock_path" 2>/dev/null; then
            _write_lock_info "$lock_path" "$my_pid" "$owner" "$purpose" "$ttl"
            echo "Checked out '$RESOLVED_NAME'" >&2
            return 0
        fi

        # Re-entrant: same PID, inherited env var, or ancestor process.
        # Ancestor re-entrancy also requires matching owner to prevent
        # unrelated ancestor processes from claiming the lock.
        local lock_pid
        lock_pid=$(_lock_field "$lock_path" "PID")
        if [ -n "$lock_pid" ]; then
            local is_reentrant=0
            if [ "$lock_pid" = "$my_pid" ]; then
                is_reentrant=1
            elif _is_ancestor_pid "$lock_pid" "$my_pid"; then
                local lock_owner
                lock_owner=$(_lock_field "$lock_path" "OWNER")
                [ "$lock_owner" = "$owner" ] && is_reentrant=1
            fi
            if [ "$is_reentrant" -eq 1 ]; then
                _write_lock_info "$lock_path" "$my_pid" "$owner" "$purpose" "$ttl"
                echo "Refreshed lock on '$RESOLVED_NAME'" >&2
                return 0
            fi
        fi

        # Shared: if same owner holds the lock, join without modifying
        if [ "${_lock_shared:-0}" -eq 1 ]; then
            local lock_owner
            lock_owner=$(_lock_field "$lock_path" "OWNER")
            if [ -n "$lock_owner" ] && [ "$lock_owner" = "$owner" ]; then
                echo "Sharing lock on '$RESOLVED_NAME' (held by $lock_owner)" >&2
                return 2
            fi
        fi

        if [ "$wait" -eq 0 ]; then
            echo "Device '$RESOLVED_NAME' is checked out:" >&2
            _show_lock_holder "$lock_path"
            return 1
        fi

        if [ "$deadline" -gt 0 ] && [ "$(date +%s)" -ge "$deadline" ]; then
            echo "Timed out waiting for '$RESOLVED_NAME' (${deadline}s):" >&2
            _show_lock_holder "$lock_path"
            return 1
        fi

        sleep 5
    done
}

# Try to checkout the first available device matching a pattern.
# Iterates through matches, skipping locked and offline devices.
# On success, prints device info to stdout.
_checkout_any() {
    local pattern="$1" owner="$2" purpose="$3" ttl="$4"

    parse_config
    mkdir -p "$LOCK_DIR"

    if ! _find_matching_indices "$pattern"; then
        echo "No devices match '$pattern'" >&2
        return 1
    fi

    local my_pid="${_lock_pid:-${USB_DEVICE_LOCK_PID:-$PPID}}"

    for i in "${MATCH_INDICES[@]}"; do
        local name="${DEVICE_NAMES[$i]}"
        local mac="${DEVICE_MACS[$i]}"

        # Skip offline devices
        if [ -n "$mac" ] && ! _is_connected "$mac"; then
            echo "skip: '$name' — offline" >&2
            continue
        fi

        # Try to acquire
        _resolve_from_index "$i"
        local lock_path
        lock_path=$(_lock_path "$RESOLVED_NAME")
        _try_reclaim_lock "$lock_path" 2>/dev/null

        if mkdir "$lock_path" 2>/dev/null; then
            _write_lock_info "$lock_path" "$my_pid" "$owner" "$purpose" "$ttl"
            echo "Checked out '$RESOLVED_NAME'" >&2
            _print_checkout_result
            return 0
        fi

        # Re-entrant: if we or an ancestor hold the lock, refresh it.
        local lock_pid
        lock_pid=$(_lock_field "$lock_path" "PID")
        if [ -n "$lock_pid" ]; then
            local is_reentrant=0
            if [ "$lock_pid" = "$my_pid" ]; then
                is_reentrant=1
            elif _is_ancestor_pid "$lock_pid" "$my_pid"; then
                local lock_owner
                lock_owner=$(_lock_field "$lock_path" "OWNER")
                [ "$lock_owner" = "$owner" ] && is_reentrant=1
            fi
            if [ "$is_reentrant" -eq 1 ]; then
                _write_lock_info "$lock_path" "$my_pid" "$owner" "$purpose" "$ttl"
                echo "Refreshed lock on '$RESOLVED_NAME'" >&2
                _print_checkout_result
                return 0
            fi
        fi

        echo "skip: '$name' — locked" >&2
    done

    echo "No available devices match '$pattern'" >&2
    return 1
}

# Print checkout result to stdout (structured, for script consumption).
_print_checkout_result() {
    local port="" bl_port=""
    if [ -n "$RESOLVED_MAC" ]; then
        port=$(find_serial_port "$RESOLVED_MAC")
        _resolve_bootloader_port 2>/dev/null
        bl_port="${RESOLVED_BOOTLOADER_PORT:-$port}"
    fi

    # Read lock PID for re-entrant inheritance
    local lock_pid=""
    local lock_path
    lock_path=$(_lock_path "$RESOLVED_NAME")
    lock_pid=$(_lock_field "$lock_path" "PID")

    if [ "${_checkout_export:-0}" -eq 1 ]; then
        # Shell-eval format: sets up the terminal for PIO + serial-monitor
        echo "export PIO_LABGRID_DEVICE='$RESOLVED_NAME'"
        # Upload port = bootloader port (PIO uploads to bootloader)
        [ -n "$bl_port" ] && echo "export PLATFORMIO_UPLOAD_PORT='$bl_port'"
        # Runtime port for test/monitor/serial-monitor
        echo "export DEVICE_NAME='$RESOLVED_NAME'"
        [ -n "$port" ] && echo "export DEVICE_PORT='$port'"
        [ -n "$bl_port" ] && [ "$bl_port" != "$port" ] && echo "export DEVICE_BOOTLOADER_PORT='$bl_port'"
        # Lock PID for re-entrant child processes
        [ -n "$lock_pid" ] && echo "export USB_DEVICE_LOCK_PID='$lock_pid'"
    else
        # Structured key=value format
        echo "DEVICE_NAME='$RESOLVED_NAME'"
        [ -n "$port" ] && echo "DEVICE_PORT='$port'"
        [ -n "$bl_port" ] && [ "$bl_port" != "$port" ] && echo "DEVICE_BOOTLOADER_PORT='$bl_port'"
        echo "DEVICE_TYPE='$RESOLVED_TYPE'"
    fi
}

cmd_checkout() {
    local wait=0 timeout=0 owner="" purpose="" ttl="0" any=0
    _lock_shared=0
    _checkout_export=0

    while [[ "${1:-}" == -* ]]; do
        case "$1" in
            --any)     any=1; shift ;;
            --export)  _checkout_export=1; shift ;;
            --wait)    wait=1; shift ;;
            --timeout) timeout="$2"; shift 2 ;;
            --owner)   owner="$2"; shift 2 ;;
            --purpose) purpose="$2"; shift 2 ;;
            --ttl)     ttl="$2"; shift 2 ;;
            --pid)     _lock_pid="$2"; shift 2 ;;
            --shared)  _lock_shared=1; shift ;;
            *)         die "unknown flag: $1" ;;
        esac
    done
    [ -n "${1:-}" ] || die "usage: usb-device checkout [--any] [--export] [--shared] [--wait] [--timeout N] [--owner STR] [--purpose STR] [--ttl N] [--pid PID] <name> [name ...]"

    mkdir -p "$LOCK_DIR"
    [ -n "$owner" ] || owner="$(whoami)@$(hostname -s)"

    # --any: find first available matching device
    if [ "$any" -eq 1 ]; then
        [ $# -eq 1 ] || die "--any requires exactly one pattern"
        _checkout_any "$1" "$owner" "$purpose" "$ttl"
        return $?
    fi

    # Tell resolve_device to filter locked devices from selection
    _RESOLVE_CHECKOUT_MODE=1

    local deadline=0
    [ "$wait" -eq 1 ] && [ "$timeout" -gt 0 ] && deadline=$(( $(date +%s) + timeout ))

    # Sort device names for deterministic acquisition order (prevents deadlock)
    local sorted_names=()
    while IFS= read -r n; do
        sorted_names+=("$n")
    done < <(printf '%s\n' "$@" | sort -f)

    # Acquire all locks in sorted order; rollback on failure
    # _checkout_one returns: 0=acquired, 2=shared (joined existing), 1=failed
    local acquired=() has_shared=0
    for name in "${sorted_names[@]}"; do
        _checkout_one "$name" "$owner" "$purpose" "$ttl" "$wait" "$deadline"
        local rc=$?
        if [ "$rc" -eq 0 ]; then
            acquired+=("$RESOLVED_NAME")
        elif [ "$rc" -eq 2 ]; then
            has_shared=1
        else
            # Rollback: release all already-acquired locks
            for held in "${acquired[@]}"; do
                local lp
                lp=$(_lock_path "$held")
                rm -rf "$lp"
                echo "Rolled back '$held'" >&2
            done
            return 1
        fi
    done

    # Print result for last acquired device
    if [ ${#acquired[@]} -gt 0 ]; then
        _print_checkout_result
    fi

    # Exit 0 if all acquired, 2 if any were shared joins
    [ "$has_shared" -eq 1 ] && return 2
    return 0
}

# Release a single device lock. Internal — called by cmd_checkin.
# Without -f, only releases locks owned by this session (matching PPID or $$).
_checkin_one() {
    local name="$1" force="$2"

    resolve_device "$name"

    local lock_path
    lock_path=$(_lock_path "$RESOLVED_NAME")

    if [ ! -d "$lock_path" ]; then
        echo "Device '$RESOLVED_NAME' is not checked out" >&2
        return 0
    fi

    if [ "$force" -eq 0 ]; then
        local lock_pid
        lock_pid=$(_lock_field "$lock_path" "PID")
        if [ -n "$lock_pid" ] && [ "$lock_pid" != "$PPID" ] && [ "$lock_pid" != "$$" ]; then
            echo "Device '$RESOLVED_NAME' is not owned by this session:" >&2
            _show_lock_holder "$lock_path"
            echo "Use -f to force release" >&2
            return 1
        fi
    fi

    rm -rf "$lock_path"
    echo "Checked in '$RESOLVED_NAME'" >&2
    return 0
}

cmd_checkin() {
    local force=0 mine=0
    while [[ "${1:-}" == -* ]]; do
        case "$1" in
            -f|--force) force=1; shift ;;
            --mine)     mine=1; shift ;;
            --pid)      _lock_pid="$2"; shift 2 ;;
            *)          die "unknown flag: $1" ;;
        esac
    done

    # No args without --mine: refuse (too easy to accidentally release all)
    if [ "$mine" -eq 0 ] && [ -z "${1:-}" ]; then
        die "usage: usb-device checkin <name> [name ...] or usb-device checkin --mine"
    fi

    # --mine: release all locks held by our PID (env var, explicit, or PPID)
    if [ "$mine" -eq 1 ]; then
        mkdir -p "$LOCK_DIR"
        parse_config
        local my_pid="${_lock_pid:-${USB_DEVICE_LOCK_PID:-$PPID}}"
        local released=0
        for i in "${!DEVICE_NAMES[@]}"; do
            local name="${DEVICE_NAMES[$i]}"
            local lock_path
            lock_path=$(_lock_path "$name")
            [ -d "$lock_path" ] || continue
            local lock_pid
            lock_pid=$(_lock_field "$lock_path" "PID")
            if [ -n "$lock_pid" ] && [ "$lock_pid" = "$my_pid" ]; then
                rm -rf "$lock_path"
                echo "Checked in '$name'" >&2
                released=$((released + 1))
            fi
        done
        if [ "$released" -eq 0 ]; then
            echo "No devices checked out by this session (pid $my_pid)" >&2
        fi
        return 0
    fi

    local failed=0
    for name in "$@"; do
        _checkin_one "$name" "$force" || failed=1
    done
    return "$failed"
}

cmd_locks() {
    local mine=0 prune=0
    while [[ "${1:-}" == -* ]]; do
        case "$1" in
            --mine)  mine=1; shift ;;
            --prune) prune=1; shift ;;
            *)       die "unknown flag: $1" ;;
        esac
    done

    mkdir -p "$LOCK_DIR"
    parse_config

    local my_pid="${_lock_pid:-${USB_DEVICE_LOCK_PID:-$PPID}}"
    local has_locks=0
    local pruned=0
    local i
    for i in "${!DEVICE_NAMES[@]}"; do
        local name="${DEVICE_NAMES[$i]}"
        local lock_path
        lock_path=$(_lock_path "$name")

        if [ -d "$lock_path" ]; then
            # Try to reclaim stale before displaying
            if _try_reclaim_lock "$lock_path"; then
                pruned=$((pruned + 1))
                continue  # was stale, now gone
            fi

            local pid
            pid=$(_lock_field "$lock_path" "PID")

            # --mine: only show locks owned by this session
            if [ "$mine" -eq 1 ] && [ "$pid" != "$my_pid" ]; then
                continue
            fi

            has_locks=1

            # --mine: output just device names (machine-readable)
            if [ "$mine" -eq 1 ]; then
                echo "$name"
                continue
            fi

            local owner purpose ts ttl
            owner=$(_lock_field "$lock_path" "OWNER")
            purpose=$(_lock_field "$lock_path" "PURPOSE")
            ts=$(_lock_field "$lock_path" "TIMESTAMP")
            ttl=$(_lock_field "$lock_path" "TTL")

            local age_str="" time_str=""
            if [ -n "$ts" ]; then
                local lock_epoch now
                now=$(date +%s)
                lock_epoch=$(_parse_utc_timestamp "$ts") || lock_epoch=0
                if [ "$lock_epoch" -gt 0 ]; then
                    age_str=$(_format_duration $((now - lock_epoch)))
                fi
                time_str=$(_format_local_time "$ts")
            fi

            local detail="${owner:-?}"
            [ -n "$purpose" ] && detail="$detail ($purpose)"
            [ -n "$time_str" ] && detail="$detail, since $time_str"
            [ -n "$age_str" ] && detail="$detail (${age_str} ago)"
            if [ -n "$pid" ]; then
                local comm
                comm=$(_lock_field "$lock_path" "COMM")
                if [ -n "$comm" ]; then
                    detail="$detail, pid=$pid ($comm)"
                else
                    detail="$detail, pid=$pid"
                fi
            fi

            printf "  %-30s  LOCKED  %s\n" "$name" "$detail"
        fi
    done

    if [ "$prune" -eq 1 ]; then
        if [ "$pruned" -gt 0 ]; then
            echo "Pruned $pruned stale lock(s)."
        else
            echo "No stale locks found."
        fi
        return 0
    fi

    if [ "$has_locks" -eq 0 ] && [ "$mine" -eq 0 ]; then
        echo "No devices are checked out."
    fi
}

# Warn (to stderr) if a device is checked out by someone else.
# Called by mutating commands (reset, off, on, bootloader, boot) as advisory.
check_lock_warning() {
    local name="$1"
    local lock_path
    lock_path=$(_lock_path "$name")
    [ -d "$lock_path" ] || return 0
    [ -f "$lock_path/info" ] || return 0

    local lock_pid
    lock_pid=$(_lock_field "$lock_path" "PID")
    # Don't warn if we hold the lock
    [ "$lock_pid" = "$PPID" ] && return 0
    [ "$lock_pid" = "$$" ] && return 0

    local owner
    owner=$(_lock_field "$lock_path" "OWNER")
    echo "WARNING: '$name' is checked out by ${owner:-unknown} (pid ${lock_pid:-?})" >&2
}

