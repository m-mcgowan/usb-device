cmd_check() {
    local ok=0 fail=0

    # Python with pyserial
    if $PYTHON -c "from serial.tools.list_ports import comports; comports()" &>/dev/null; then
        echo "[ok] python + pyserial ($PYTHON)"
        ok=$((ok + 1))
    else
        echo "[FAIL] python + pyserial ($PYTHON)"
        fail=$((fail + 1))
    fi

    # jq
    if command -v jq &>/dev/null; then
        echo "[ok] jq ($(which jq))"
        ok=$((ok + 1))
    else
        echo "[FAIL] jq not found"
        fail=$((fail + 1))
    fi

    # uhubctl
    if command -v uhubctl &>/dev/null; then
        echo "[ok] uhubctl ($(which uhubctl))"
        ok=$((ok + 1))
        # Check sudo access
        if sudo -n uhubctl &>/dev/null 2>&1 || sudo -n uhubctl 2>&1 | grep -q "hub"; then
            echo "[ok] uhubctl sudo (passwordless)"
            ok=$((ok + 1))
        else
            echo "[warn] uhubctl sudo requires password — run setup.sh to fix"
        fi
    else
        echo "[FAIL] uhubctl not found — brew install uhubctl"
        fail=$((fail + 1))
    fi

    # Config files
    if [ -f "$CONF" ]; then
        parse_config
        echo "[ok] devices.conf (${#DEVICE_NAMES[@]} device(s) registered)"
        ok=$((ok + 1))
    else
        echo "[FAIL] devices.conf not found at $CONF"
        fail=$((fail + 1))
    fi

    if [ -f "$DB" ]; then
        echo "[ok] locations.json"
        ok=$((ok + 1))
    else
        echo "[warn] locations.json not found — run 'usb-device scan' to create"
    fi

    # Per-type plugin checks
    if [ "$CONFIG_PARSED" -eq 1 ]; then
        local checked_types=()
        for i in "${!DEVICE_TYPES[@]}"; do
            local t="${DEVICE_TYPES[$i]}"
            [ "$t" = "generic" ] && continue
            [[ " ${checked_types[*]:-} " == *" $t "* ]] && continue
            checked_types+=("$t")

            if load_type_plugin "$t"; then
                if declare -f "type_${t}_check" >/dev/null 2>&1; then
                    local type_fail=0
                    "type_${t}_check" || type_fail=$?
                    ok=$((ok + 1))
                    fail=$((fail + type_fail))
                fi
            else
                echo "[warn] no plugin for type=$t (used by ${DEVICE_NAMES[$i]})"
            fi
        done
    fi

    echo ""
    if [ "$fail" -gt 0 ]; then
        echo "$ok ok, $fail failed — run setup.sh to fix"
        return 1
    else
        echo "All $ok checks passed."
    fi
}

cmd_scan() {
    parse_config
    echo "Scanning USB bus..."
    local found=0 updated=0
    db_init

    local i
    for i in "${!DEVICE_NAMES[@]}"; do
        local name="${DEVICE_NAMES[$i]}"
        local mac="${DEVICE_MACS[$i]}"
        local type="${DEVICE_TYPES[$i]}"
        local location="${DEVICE_LOCATIONS[$i]}"

        # Static-location devices: verify hub:port exists in uhubctl
        if [ -n "$location" ]; then
            local hub port
            read -r hub port <<< "$(parse_static_location "$location")"
            # Check if uhubctl can see this hub
            if uhubctl -l "$hub" -p "$port" 2>/dev/null | grep -q "Port $port"; then
                db_put "$name" "${mac:--}" "$hub" "$port" "static" "-"
                printf "  %-30s  location=%-10s type=%-6s [verified]\n" "$name" "$location" "$type"
                found=$((found + 1))
                updated=$((updated + 1))
            else
                printf "  %-30s  location=%-10s type=%-6s [hub:port not found in uhubctl]\n" "$name" "$location" "$type"
            fi
            continue
        fi

        # Serial-number-based devices
        local result serial_port
        serial_port=$(find_serial_port "$mac")

        if result=$(find_hub_port_live "$mac"); then
            read -r hub port how <<< "$result"
            db_evict_port "$hub" "$port" "$name"
            db_put "$name" "$mac" "$hub" "$port" "$how" "${serial_port:--}"
            local mode_tag="found"
            if [ "$type" = "insight_hub" ]; then
                local mode
                mode=$(detect_device_mode "$mac")
                [ "$mode" = "bootloader" ] && mode_tag="found, BOOTLOADER"
            fi
            printf "  %-30s  hub=%-6s port=%-4s dev=%-25s [%s]\n" "$name" "$hub" "$port" "${serial_port:--}" "$mode_tag"
            found=$((found + 1))
            updated=$((updated + 1))
        elif [ -n "$serial_port" ]; then
            local mode_tag="found, no power-switchable hub"
            if [ "$type" = "insight_hub" ]; then
                local mode
                mode=$(detect_device_mode "$mac")
                [ "$mode" = "bootloader" ] && mode_tag="found, BOOTLOADER, no power-switchable hub"
            fi
            db_put "$name" "$mac" "-" "-" "no-hub" "${serial_port}"
            printf "  %-30s  dev=%-25s [%s]\n" "$name" "$serial_port" "$mode_tag"
            found=$((found + 1))
            updated=$((updated + 1))
        else
            local cached_hub
            cached_hub=$(db_get "$name" "hub")
            if [ -n "$cached_hub" ]; then
                local cached_port cached_ts
                cached_port=$(db_get "$name" "port")
                cached_ts=$(db_get "$name" "last_seen")
                printf "  %-30s  hub=%-6s port=%-4s %s [cached from %s]\n" "$name" "$cached_hub" "$cached_port" "" "$cached_ts"
            else
                printf "  %-30s  %s\n" "$name" "[not found, no cached location]"
            fi
        fi
    done

    echo ""
    echo "Scan complete: $found device(s) found, $updated location(s) updated."
}

cmd_discover() {
    parse_config

    # Enumerate all USB serial ports via Python
    local all_ports
    all_ports=$($PYTHON -c "
from serial.tools.list_ports import comports
for p in comports():
    sn = p.serial_number or ''
    if not sn:
        continue
    mfg = p.manufacturer or '-'
    prod = p.product or '-'
    loc = p.location or '-'
    print(f'{sn}\t{p.device}\t{mfg}\t{prod}\t{loc}')
" 2>/dev/null)

    [ -n "$all_ports" ] || { echo "No unregistered USB devices found."; return 0; }

    # Filter out registered devices and deduplicate by serial
    local found=0 seen_serials=""
    while IFS=$'\t' read -r serial device manufacturer product location; do
        [ -z "$serial" ] && continue
        local norm
        norm=$(normalize_mac "$serial")

        # Skip registered devices
        local registered=0 i
        for i in "${!DEVICE_MACS[@]}"; do
            if [ "$(normalize_mac "${DEVICE_MACS[$i]}")" = "$norm" ]; then
                registered=1
                break
            fi
        done
        [ "$registered" -eq 1 ] && continue

        # Deduplicate by serial
        case "$seen_serials" in
            *"$norm"*) continue ;;
        esac
        seen_serials="$seen_serials $norm"

        if [ "$found" -eq 0 ]; then
            echo "Unregistered USB devices:"
            echo ""
        fi
        found=$((found + 1))
        printf "  %-20s  %-30s  %s %s  location=%s\n" "$serial" "$device" "${manufacturer:--}" "${product:--}" "${location:--}"
    done <<< "$all_ports"

    if [ "$found" -eq 0 ]; then
        echo "No unregistered USB devices found."
    else
        echo ""
        echo "$found unregistered device(s). Register with:"
        echo "  usb-device register <name> --serial <SERIAL> --type <TYPE>"
        echo "  usb-device register <role> --serial <SERIAL> --type <TYPE> --partner-of <DEVICE>"
    fi
}

cmd_list() {
    parse_config
    echo "Registered devices:"
    echo ""

    local i
    for i in "${!DEVICE_NAMES[@]}"; do
        local name="${DEVICE_NAMES[$i]}"
        local mac="${DEVICE_MACS[$i]}"
        local type="${DEVICE_TYPES[$i]}"
        local location="${DEVICE_LOCATIONS[$i]}"

        # Static-location devices
        if [ -n "$location" ]; then
            local hub port
            read -r hub port <<< "$(parse_static_location "$location")"
            local power_state=""
            if uhubctl -l "$hub" -p "$port" 2>/dev/null | grep -q "power"; then
                power_state="[power on]"
                uhubctl -l "$hub" -p "$port" 2>/dev/null | grep -q "off" && power_state="[power off]"
            fi
            printf "  %-30s  type=%-11s location=%-10s %s\n" "$name" "$type" "$location" "$power_state"
            continue
        fi

        # Serial-number-based devices
        local result serial_port
        serial_port=$(find_serial_port "$mac")
        if result=$(find_hub_port_live "$mac"); then
            read -r hub port how <<< "$result"
            local label="[connected]"
            [ "$how" = "indirect" ] && label="[connected via sub-hub]"
            printf "  %-30s  type=%-11s id=%-20s hub=%-6s port=%-4s dev=%-25s %s\n" "$name" "$type" "$mac" "$hub" "$port" "${serial_port:--}" "$label"
        elif [ -n "$serial_port" ]; then
            printf "  %-30s  type=%-11s id=%-20s dev=%-25s %s\n" "$name" "$type" "$mac" "$serial_port" "[connected, no power-switchable hub]"
        else
            local db_hub db_port db_ts
            db_hub=$(db_get "$name" "hub")
            db_port=$(db_get "$name" "port")
            db_ts=$(db_get "$name" "last_seen")
            if [ -n "$db_hub" ] && [ "$db_hub" != "-" ]; then
                printf "  %-30s  type=%-11s id=%-20s hub=%-6s port=%-4s dev=%-25s [offline, last seen %s]\n" \
                    "$name" "$type" "$mac" "$db_hub" "$db_port" "-" "$db_ts"
            elif [ -n "$db_ts" ]; then
                printf "  %-30s  type=%-11s id=%-20s %s\n" "$name" "$type" "$mac" "[offline, last seen $db_ts]"
            else
                printf "  %-30s  type=%-11s id=%-20s %s\n" "$name" "$type" "$mac" "[not found]"
            fi
        fi
    done
}

# Check if a device is locked (not stale). Returns 0 if locked, 1 if free.
# Sets LOCK_OWNER, LOCK_PURPOSE, LOCK_PID if locked.
_is_locked() {
    local name="$1"
    local lock_path
    lock_path=$(_lock_path "$name")
    [ -d "$lock_path" ] || return 1
    # Reclaim stale locks silently
    if _try_reclaim_lock "$lock_path" 2>/dev/null; then
        return 1
    fi
    LOCK_OWNER=$(_lock_field "$lock_path" "OWNER")
    LOCK_PURPOSE=$(_lock_field "$lock_path" "PURPOSE")
    LOCK_PID=$(_lock_field "$lock_path" "PID")
    return 0
}

# Check if a device is connected (has a serial port or live hub port).
_is_connected() {
    local mac="$1"
    [ -z "$mac" ] && return 1
    local serial_port
    serial_port=$(find_serial_port "$mac")
    [ -n "$serial_port" ] && return 0
    find_hub_port_live "$mac" >/dev/null 2>&1
}

# Print info for a single resolved device (shared by cmd_find and _find_available).
_print_device_info() {
    resolve_hub_port
    echo "name: $RESOLVED_NAME"
    echo "type: $RESOLVED_TYPE"
    if [ -n "$RESOLVED_LOCATION" ]; then
        echo "location: $RESOLVED_LOCATION"
    fi
    if [ -n "$RESOLVED_MAC" ]; then
        echo "id:   $RESOLVED_MAC"
    fi
    echo "hub:  $HUB"
    echo "port: $PORT"
    echo "link: $HOW"
    [ "${CACHED:-}" = "cached" ] && echo "src:  cached (last-known)"
    if [ -n "$RESOLVED_MAC" ]; then
        local serial_port
        serial_port=$(find_serial_port "$RESOLVED_MAC")
        echo "dev:  ${serial_port:--}"
    fi
    if [ -n "$RESOLVED_CHIP" ]; then
        echo "chip: $RESOLVED_CHIP"
    fi
    if [ -n "$RESOLVED_HUB_NAME" ]; then
        echo "hub_name: $RESOLVED_HUB_NAME"
    fi
    # Show type-specific commands if plugin available
    local type_cmds
    type_cmds=$(get_type_commands "$RESOLVED_TYPE")
    [ -n "$type_cmds" ] && echo "cmds: $type_cmds"
    # Show lock status
    mkdir -p "$LOCK_DIR"
    if _is_locked "$RESOLVED_NAME"; then
        local detail="$LOCK_OWNER"
        [ -n "$LOCK_PURPOSE" ] && detail="$detail ($LOCK_PURPOSE)"
        echo "lock: LOCKED by $detail"
    else
        echo "lock: available"
    fi
}

cmd_find() {
    local available=0
    while [[ "${1:-}" == -* ]]; do
        case "$1" in
            -a|--available) available=1; shift ;;
            *)              die "unknown flag: $1" ;;
        esac
    done

    if [ "$available" -eq 1 ]; then
        _find_available "${1:-}"
        return $?
    fi

    # resolve_device unless already resolved (chained mode)
    if [ -n "${1:-}" ]; then
        resolve_device "$1"
    elif [ -z "$RESOLVED_NAME" ]; then
        die "usage: usb-device find [-a|--available] <name>"
    fi
    _print_device_info
    return 0
}

# Find the first matching device that is connected and not locked.
# Outputs device info. Exits non-zero if none available.
_find_available() {
    local pattern="${1:-}"
    [ -n "$pattern" ] || die "usage: usb-device find --available <pattern>"

    parse_config
    mkdir -p "$LOCK_DIR"

    if ! _find_matching_indices "$pattern"; then
        echo "No devices match '$pattern'" >&2
        return 1
    fi

    # Find first that is connected and not locked
    for i in "${MATCH_INDICES[@]}"; do
        local name="${DEVICE_NAMES[$i]}"
        local mac="${DEVICE_MACS[$i]}"

        # Skip locked
        if _is_locked "$name"; then
            echo "skip: '$name' — locked by ${LOCK_OWNER:-?}" >&2
            continue
        fi

        # Skip disconnected
        if [ -n "$mac" ] && ! _is_connected "$mac"; then
            echo "skip: '$name' — offline" >&2
            continue
        fi

        # Found one — resolve and print
        _resolve_from_index "$i"
        _print_device_info
        return 0
    done

    echo "No available devices match '$pattern'" >&2
    return 1
}

# Get commands supported by a device type (from plugin).
# Returns space-separated list, or empty if no plugin.
get_type_commands() {
    local t="$1"
    load_type_plugin "$t" || true
    if declare -f "type_${t}_commands" >/dev/null 2>&1; then
        "type_${t}_commands"
    fi
}

cmd_reset() {
    local force=0
    # Parse flags before the device name
    while [[ "${1:-}" == -* ]]; do
        case "$1" in
            -f|--force) force=1; shift ;;
            *) die "unknown flag: $1" ;;
        esac
    done
    if [ -n "${1:-}" ]; then
        resolve_device "$1"
    elif [ -z "$RESOLVED_NAME" ]; then
        die "usage: usb-device reset [-f|--force] <name>"
    fi
    check_lock_warning "$RESOLVED_NAME"

    # ── Step 0: Try type plugin reset (e.g. esptool RTS/DTR for ESP32)
    # This works for battery-powered devices where USB power cycling won't reset the MCU.
    load_type_plugin "$RESOLVED_TYPE" 2>/dev/null || true
    local reset_func="type_${RESOLVED_TYPE}_reset"
    if declare -f "$reset_func" >/dev/null 2>&1; then
        RESOLVED_PORT=$(find_serial_port "$RESOLVED_MAC")
        if [ -n "$RESOLVED_PORT" ]; then
            "$reset_func" "$RESOLVED_PORT" "$RESOLVED_NAME"
            # Wait for re-enumeration (port may change after reset)
            sleep 2
            if device_is_alive "$RESOLVED_MAC"; then
                return 0
            fi
            echo "Device did not re-enumerate after type reset — falling through to power cycle"
        fi
    fi

    resolve_hub_port

    # ── Step 1: insight_hub special case — use serial API (uhubctl can't power-cycle the on-board hub)
    if [ "$RESOLVED_TYPE" = "insight_hub" ]; then
        local mode
        mode=$(detect_device_mode "$RESOLVED_MAC")
        if [ "$mode" = "bootloader" ]; then
            echo "Device is in ROM bootloader — clearing FORCE_DOWNLOAD_BOOT via esptool..."
            RESOLVED_PORT=$(find_serial_port "$RESOLVED_MAC")
            if [ -n "$RESOLVED_PORT" ]; then
                dispatch_type_action "boot"
                return $?
            fi
            echo "Bootloader port not found — falling through to power cycle" >&2
        elif [ "$mode" = "app" ]; then
            RESOLVED_PORT=$(find_serial_port "$RESOLVED_MAC")
            if [ -n "$RESOLVED_PORT" ]; then
                dispatch_type_action "restart"
                return $?
            fi
        fi
    fi

    # ── Step 2: Try port-level power cycle ────────────────────────
    local using_insight_hub=0
    if _is_insight_hub_device; then
        using_insight_hub=1
        echo "Resetting '$RESOLVED_NAME' via Insight Hub $INSIGHT_HUB_CHANNEL..."
        _insight_hub_power cycle 2
    else
        echo "Resetting '$RESOLVED_NAME' on hub $HUB port $PORT..."
        sudo uhubctl -a cycle -d 2 -l "$HUB" -p "$PORT" 2>&1
    fi

    # Wait for device to re-enumerate
    echo "Waiting for device to re-enumerate..."
    local attempts=0
    while [ $attempts -lt 10 ]; do
        sleep 1
        if device_is_alive "$RESOLVED_MAC"; then
            echo "Device '$RESOLVED_NAME' is back online."
            # Update DB with current location
            local new_result new_serial
            new_serial=$(find_serial_port "$RESOLVED_MAC")
            if new_result=$(find_hub_port_live "$RESOLVED_MAC"); then
                read -r new_hub new_port new_how <<< "$new_result"
                db_put "$RESOLVED_NAME" "$RESOLVED_MAC" "$new_hub" "$new_port" "$new_how" "${new_serial:--}"
            fi
            return 0
        fi
        attempts=$((attempts + 1))
    done

    echo ""
    echo "Device did not come back after port-level reset."

    # ── Step 3: Escalate ──────────────────────────────────────────
    if [ "$using_insight_hub" -eq 1 ]; then
        # Renesas hub chip doesn't support uhubctl — retry via serial API
        # with a fresh connection (re-detect in case the port changed).
        echo "Retrying Insight Hub power cycle (fresh connection)..."
        INSIGHT_HUB_LOCATION=""
        if _insight_hub_detect && _is_insight_hub_device; then
            _insight_hub_power cycle 3
        else
            echo "Could not re-detect Insight Hub for retry." >&2
        fi
    else
        echo "Escalating to hub-level power cycle (hub $HUB)..."

        # Find other known devices on this hub
        local other_devices
        other_devices=$(db_devices_on_hub "$HUB" "$PORT")

        if [ -n "$other_devices" ]; then
            echo ""
            echo "WARNING: The following devices are also on hub $HUB and will be power-cycled:"
            while IFS='|' read -r dev_name dev_port; do
                echo "  - $dev_name (port $dev_port)"
            done <<< "$other_devices"
            echo ""

            if [ "$force" -eq 0 ]; then
                if [ -t 0 ]; then
                    printf "Continue with hub reset? [y/N] "
                    local answer
                    read -r answer
                    case "$answer" in
                        [yY]|[yY][eE][sS]) ;;
                        *) echo "Aborted."; exit 1 ;;
                    esac
                else
                    echo "Non-interactive mode and --force not set. Aborting hub reset."
                    exit 1
                fi
            else
                echo "(--force: proceeding without confirmation)"
            fi
        fi

        # Cycle all ports on the hub
        sudo uhubctl -a cycle -l "$HUB" 2>&1
    fi

    echo "Waiting for device to re-enumerate after hub reset..."
    attempts=0
    while [ $attempts -lt 15 ]; do
        sleep 1
        if device_is_alive "$RESOLVED_MAC"; then
            echo "Device '$RESOLVED_NAME' is back online."
            local new_result new_serial
            new_serial=$(find_serial_port "$RESOLVED_MAC")
            if new_result=$(find_hub_port_live "$RESOLVED_MAC"); then
                read -r new_hub new_port new_how <<< "$new_result"
                db_put "$RESOLVED_NAME" "$RESOLVED_MAC" "$new_hub" "$new_port" "$new_how" "${new_serial:--}"
            fi
            return 0
        fi
        attempts=$((attempts + 1))
    done

    # ── Step 4: Escalate to parent hub power cycle ─────────────────
    local parent_hub="${HUB%.*}"
    if [ "$parent_hub" != "$HUB" ] && [ -n "$parent_hub" ]; then
        local child_port="${HUB##*.}"
        echo ""
        echo "Device did not come back after hub reset."
        echo "Escalating to parent hub power cycle ($parent_hub port $child_port)..."
        sudo uhubctl -a cycle -d 2 -l "$parent_hub" -p "$child_port" 2>&1

        echo "Waiting for device to re-enumerate after parent hub reset..."
        attempts=0
        while [ $attempts -lt 15 ]; do
            sleep 1
            if device_is_alive "$RESOLVED_MAC"; then
                echo "Device '$RESOLVED_NAME' is back online."
                local new_result new_serial
                new_serial=$(find_serial_port "$RESOLVED_MAC")
                if new_result=$(find_hub_port_live "$RESOLVED_MAC"); then
                    read -r new_hub new_port new_how <<< "$new_result"
                    db_put "$RESOLVED_NAME" "$RESOLVED_MAC" "$new_hub" "$new_port" "$new_how" "${new_serial:--}"
                fi
                return 0
            fi
            attempts=$((attempts + 1))
        done
    fi

    echo "Device '$RESOLVED_NAME' did not come back after hub reset."
    return 1
}

cmd_off() {
    resolve_device "$1"
    check_lock_warning "$RESOLVED_NAME"
    resolve_hub_port
    if _is_insight_hub_device; then
        echo "Powering off '$RESOLVED_NAME' via Insight Hub $INSIGHT_HUB_CHANNEL..."
        _insight_hub_power off
    else
        echo "Powering off '$RESOLVED_NAME' on hub $HUB port $PORT..."
        sudo uhubctl -a off -l "$HUB" -p "$PORT"
    fi
}

cmd_on() {
    resolve_device "$1"
    check_lock_warning "$RESOLVED_NAME"
    resolve_hub_port
    if _is_insight_hub_device; then
        echo "Powering on '$RESOLVED_NAME' via Insight Hub $INSIGHT_HUB_CHANNEL..."
        _insight_hub_power on
    else
        echo "Powering on '$RESOLVED_NAME' on hub $HUB port $PORT..."
        sudo uhubctl -a on -l "$HUB" -p "$PORT"
    fi
}

# Require serial port for the resolved device. Sets RESOLVED_PORT.
require_serial_port() {
    [ -n "$RESOLVED_MAC" ] || die "'$RESOLVED_NAME' (type=$RESOLVED_TYPE) has no serial number — no serial port available"
    RESOLVED_PORT=$(find_serial_port "$RESOLVED_MAC")
    [ -n "$RESOLVED_PORT" ] || die "no serial port found for '$RESOLVED_NAME' ($RESOLVED_MAC)"
}

# Dispatch to a type plugin action. Dies with a clear message if no plugin.
# Usage: dispatch_type_action <action>
dispatch_type_action() {
    local action="$1"
    local func="type_${RESOLVED_TYPE}_${action}"
    load_type_plugin "$RESOLVED_TYPE" || true
    if declare -f "$func" >/dev/null 2>&1; then
        "$func" "$RESOLVED_PORT" "$RESOLVED_NAME"
    else
        die "'$RESOLVED_NAME' (type=$RESOLVED_TYPE) — no $action support (no plugin for type=$RESOLVED_TYPE)"
    fi
}

cmd_port() {
    local bootloader=0
    while [[ "${1:-}" == -* ]]; do
        case "$1" in
            --bootloader|-b) bootloader=1; shift ;;
            *)               die "unknown flag: $1" ;;
        esac
    done
    # resolve_device unless already resolved (chained mode)
    if [ -n "${1:-}" ]; then
        resolve_device "$1"
    elif [ -z "$RESOLVED_NAME" ]; then
        die "usage: usb-device port [-b|--bootloader] <name>"
    fi
    if [ "$bootloader" -eq 1 ]; then
        _resolve_bootloader_port || die "no bootloader port found for '$RESOLVED_NAME'"
        echo "$RESOLVED_BOOTLOADER_PORT"
    else
        require_serial_port
        echo "$RESOLVED_PORT"
    fi
}

# Resolve the bootloader port for the current device.
# Uses bootloader_mac field from devices.conf if present, otherwise falls back
# to the runtime port (same MAC). Sets RESOLVED_BOOTLOADER_PORT.
# Returns 1 if port can't be resolved.
_resolve_bootloader_port() {
    RESOLVED_BOOTLOADER_PORT=""
    local bl_mac
    bl_mac=$(cmd_field "$RESOLVED_NAME" "bootloader_mac" 2>/dev/null) || true
    if [ -n "$bl_mac" ]; then
        RESOLVED_BOOTLOADER_PORT=$(find_serial_port "$bl_mac")
        [ -n "$RESOLVED_BOOTLOADER_PORT" ] || return 1
    elif [ -n "$RESOLVED_MAC" ]; then
        RESOLVED_BOOTLOADER_PORT=$(find_serial_port "$RESOLVED_MAC")
        [ -n "$RESOLVED_BOOTLOADER_PORT" ] || return 1
    else
        return 1
    fi
}

cmd_env() {
    resolve_device "$1"
    local port="" bl_port=""
    if [ -n "$RESOLVED_MAC" ]; then
        port=$(find_serial_port "$RESOLVED_MAC")
        _resolve_bootloader_port 2>/dev/null
        bl_port="${RESOLVED_BOOTLOADER_PORT:-$port}"
    fi
    echo "export PIO_LABGRID_DEVICE='$RESOLVED_NAME'"
    [ -n "$bl_port" ] && echo "export PLATFORMIO_UPLOAD_PORT='$bl_port'"
    echo "export DEVICE_NAME='$RESOLVED_NAME'"
    [ -n "$port" ] && echo "export DEVICE_PORT='$port'"
    [ -n "$bl_port" ] && [ "$bl_port" != "$port" ] && echo "export DEVICE_BOOTLOADER_PORT='$bl_port'"
}

# ── Type-dispatched commands ───────────────────────────────────────

cmd_type() {
    resolve_device "$1"
    echo "$RESOLVED_TYPE"
}

# Print the value of an arbitrary key from a device's section in devices.conf.
# Useful for project-specific metadata (e.g. notecard_uid, serial_number).
# Exits non-zero and prints nothing if the key is absent.
cmd_field() {
    local name="$1" key="$2"
    [ -n "$name" ] || die "usage: usb-device field <name> <key>"
    [ -n "$key"  ] || die "usage: usb-device field <name> <key>"
    local val
    val=$(awk -v section="[$name]" -v k="$key" '
        $0 == section   { in_s=1; next }
        /^\[/           { in_s=0 }
        in_s && $0 ~ "^"k"[ \t]*=" {
            sub(/^[^=]*=[ \t]*/, "")
            print
            exit
        }
    ' "$CONF")
    [ -n "$val" ] || return 1
    echo "$val"
}

cmd_bootloader() {
    resolve_device "$1"
    check_lock_warning "$RESOLVED_NAME"
    require_serial_port
    dispatch_type_action "bootloader"
}

cmd_boot() {
    resolve_device "$1"
    check_lock_warning "$RESOLVED_NAME"
    require_serial_port
    dispatch_type_action "boot"
}

# ── Insight Hub integration ────────────────────────────────────────

cmd_hub() {
    local subcmd="${1:-status}"
    shift 2>/dev/null || true
    parse_config

    local hub_args=()
    # Pass hub config if set
    [ -n "$HUB_CONF_PORT" ] && hub_args+=(--hub-port "$HUB_CONF_PORT")
    [ -n "$HUB_CONF_LOCATION" ] && hub_args+=(--hub-location "$HUB_CONF_LOCATION")
    # Pass device registry as JSON
    hub_args+=(--config "$CONF")

    case "$subcmd" in
        status)    $PYTHON -u "${SCRIPT_DIR}/hub_agent.py" "${hub_args[@]}" --status "$@" ;;
        sync)      $PYTHON -u "${SCRIPT_DIR}/hub_agent.py" "${hub_args[@]}" --once "$@" ;;
        watch)     $PYTHON -u "${SCRIPT_DIR}/hub_agent.py" "${hub_args[@]}" "$@" ;;
        install)   $PYTHON -u "${SCRIPT_DIR}/hub_agent.py" --install ;;
        uninstall) $PYTHON -u "${SCRIPT_DIR}/hub_agent.py" --uninstall ;;
        log)       local logfile="$HOME/Library/Logs/hub-agent.log"
                   [ -f "$logfile" ] && tail -f "$logfile" || echo "No log file: $logfile" ;;
        *)         die "unknown hub command: $subcmd (try: status, sync, watch, install, uninstall, log)" ;;
    esac
}

# ── Register ──────────────────────────────────────────────────────

cmd_register() {
    local name="" mac="" type="esp32" chip="esp32s3" hub_name="" port="" partner_of=""

    # First positional arg is the device name
    while [ $# -gt 0 ]; do
        case "$1" in
            --port)       port="$2"; shift 2 ;;
            --mac|--serial) mac="$2"; shift 2 ;;
            --type)       type="$2"; shift 2 ;;
            --chip)       chip="$2"; shift 2 ;;
            --hub-name)   hub_name="$2"; shift 2 ;;
            --partner-of) partner_of="$2"; shift 2 ;;
            -*)           die "unknown flag: $1" ;;
            *)
                if [ -z "$name" ]; then
                    name="$1"; shift
                else
                    die "unexpected argument: $1"
                fi
                ;;
        esac
    done

    [ -n "$name" ] || die "usage: usb-device register <name> --port /dev/cu.* | --mac AA:BB:CC:DD:EE:FF [--type TYPE] [--chip CHIP] [--hub-name NAME] [--partner-of DEVICE]"

    # Resolve partner-of to compose the full section name (e.g. "Board:ppk2")
    if [ -n "$partner_of" ]; then
        parse_config
        resolve_device "$partner_of"
        [ -n "$RESOLVED_NAME" ] || die "no device matches '$partner_of'"
        # The positional arg is the role, compose the full name
        name="${RESOLVED_NAME}:${name}"
    fi

    # Auto-detect from port
    if [ -n "$port" ]; then
        local detect_result
        detect_result=$($PYTHON -c "
from serial.tools.list_ports import comports
port = '$port'
for p in comports():
    if p.device == port:
        print((p.serial_number or '') + '\t' + (p.description or ''))
        break
" 2>/dev/null)
        if [ -z "$detect_result" ]; then
            die "no device found on port $port"
        fi
        local detected_serial detected_desc
        detected_serial="${detect_result%%	*}"
        detected_desc="${detect_result##*	}"
        if [ -z "$detected_serial" ]; then
            die "device on $port has no serial number — use --mac to specify manually"
        fi
        mac="$detected_serial"
        echo "Detected: $detected_desc"
        echo "Serial:   $mac"
    fi

    [ -n "$mac" ] || die "must specify --port or --mac"

    # Check for duplicate name
    [ -z "$partner_of" ] && parse_config
    local i
    for i in "${!DEVICE_NAMES[@]}"; do
        if [ "${DEVICE_NAMES[$i]}" = "$name" ]; then
            die "device '$name' is already registered (mac=${DEVICE_MACS[$i]})"
        fi
    done

    # Create config dir if needed
    mkdir -p "$(dirname "$CONF")"

    # Append INI section — partner devices use serial= and skip chip=
    if [ -n "$partner_of" ]; then
        {
            echo ""
            echo "[$name]"
            echo "serial=$mac"
            echo "type=$type"
        } >> "$CONF"
        echo "Registered partner '$name' (serial=$mac, type=$type)"
    else
        {
            echo ""
            echo "[$name]"
            echo "mac=$mac"
            echo "type=$type"
            [ -n "$chip" ] && echo "chip=$chip"
            [ -n "$hub_name" ] && echo "hub_name=$hub_name"
        } >> "$CONF"
        echo "Registered '$name' (mac=$mac, type=$type, chip=$chip)"
    fi

    # Reset parser cache and scan
    CONFIG_PARSED=0
    echo ""
    cmd_scan
}

# ── Main dispatch ─────────────────────────────────────────────────

# Commands that don't take a device name
case "${1:-}" in
    version)        echo "usb-device $USB_DEVICE_VERSION"; exit ;;
    help|--help|-h) cmd_help; exit ;;
    list)           cmd_list; exit ;;
    scan)           cmd_scan; exit ;;
    discover)       cmd_discover; exit ;;
    check)          cmd_check; exit ;;
    locks)          shift; cmd_locks "$@"; exit ;;
    register)       shift; cmd_register "$@"; exit ;;
    hub)            shift; cmd_hub "$@"; exit ;;
esac

# Dispatch a single command. If RESOLVED_NAME is already set, use it.
# Otherwise, the command must provide a device name.
dispatch_cmd() {
    local cmd="$1"; shift
    case "$cmd" in
        find)       cmd_find "$@" ;;
        field)      cmd_field "${1:-$RESOLVED_NAME}" "${2:-}" ;;
        type)       cmd_type "${1:-$RESOLVED_NAME}" ;;
        reset)      cmd_reset "$@" ;;
        off)        cmd_off "${1:-$RESOLVED_NAME}" ;;
        on)         cmd_on "${1:-$RESOLVED_NAME}" ;;
        port)       cmd_port "$@" ;;
        env)        cmd_env "${1:-$RESOLVED_NAME}" ;;
        bootloader) cmd_bootloader "${1:-$RESOLVED_NAME}" ;;
        boot)       cmd_boot "${1:-$RESOLVED_NAME}" ;;
        checkout)   cmd_checkout "$@" ;;
        checkin)    cmd_checkin "$@" ;;
        *)          die "unknown command: $cmd" ;;
    esac
}

# Traditional: usb-device <command> <device>
# Chained:    usb-device <device> <cmd1> [cmd2] ...
is_command() {
    case "$1" in
        find|field|type|reset|off|on|port|env|bootloader|boot|checkout|checkin) return 0 ;;
        *) return 1 ;;
    esac
}

if [ -z "${1:-}" ]; then
    cmd_help
    exit 1
fi

if is_command "$1"; then
    # Traditional: usb-device <command> [flags] <device>
    cmd="$1"; shift
    case "$cmd" in
        reset|checkout|checkin|find|field|port) dispatch_cmd "$cmd" "$@" ;;
        *)
            [ -n "${1:-}" ] || die "usage: usb-device $cmd <name>"
            dispatch_cmd "$cmd" "$1"
            ;;
    esac
else
    # Chained: usb-device <device> <cmd1> [cmd2] ...
    # If it doesn't resolve as a device and there's no follow-up command,
    # it's likely a typo or unknown command — say so.
    if [ $# -eq 1 ]; then
        die "unknown command: $1"
    fi
    resolve_device "$1"; shift
    while [ $# -gt 0 ]; do
        is_command "$1" || die "unknown command: $1"
        dispatch_cmd "$1"
        shift
    done
fi
